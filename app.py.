from flask import Flask, render_template, jsonify
import random # Pour simuler des données de trafic

app = Flask(__name__)

@app.route('/')
def index():
    return render_template('index.html')

@app.route('/api/stats')
def stats():
    # Simulation de données réseau (IP, CPU, Trafic)
    data = {
        "cpu_usage": random.randint(10, 80),
        "active_connections": random.randint(5, 50),
        "status": "Secure"
    }
    return jsonify(data)

if __name__ == '__main__':
    app.run(debug=True)
